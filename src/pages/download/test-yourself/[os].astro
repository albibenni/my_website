---
export function getStaticPaths() {
  return [
    { params: { os: "mac" } },
    { params: { os: "windows" } },
    { params: { os: "linux" } },
  ];
}
const { os } = Astro.params;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Downloading Test Yourself...</title>
    <script is:inline define:vars={{ os }}>
      async function downloadLatest() {
        try {
          const res = await fetch(
            "https://api.github.com/repos/albibenni/test-yourself/releases/latest",
          );
          const data = await res.json();

          let ext = ".dmg";
          if (os === "windows") ext = ".exe";
          if (os === "linux") ext = ".AppImage";

          // Find the correct asset by extension
          const asset = data.assets.find((a) => a.name.endsWith(ext));

          if (asset) {
            window.location.replace(asset.browser_download_url);
          } else {
            // Fallback to releases page
            window.location.replace(
              "https://github.com/albibenni/test-yourself/releases/latest",
            );
          }
        } catch (error) {
          window.location.replace(
            "https://github.com/albibenni/test-yourself/releases/latest",
          );
        }
      }

      // Start the download immediately
      downloadLatest();
    </script>
  </head>
  <body
    class="flex min-h-screen items-center justify-center bg-zinc-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100"
    style="display: flex; align-items: center; justify-content: center; min-height: 100vh; font-family: sans-serif;"
  >
    <p>
      Finding the latest {
        os === "mac" ? "macOS" : os === "windows" ? "Windows" : "Linux"
      } version...
    </p>
  </body>
</html>
