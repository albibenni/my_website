---
import type { Project } from "@/data/projects";
import { useTranslations, translatePath, type Locale } from "@/i18n";

interface Props {
  project: Project;
  locale: Locale;
}

const { project, locale } = Astro.props;
const t = useTranslations(locale);
---

<article
  class="project-card relative flex flex-col rounded-lg border border-zinc-200 p-5 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:hover:border-zinc-600"
  data-tags={project.tags.join(",")}
>
  <h3 class="font-semibold text-zinc-900 dark:text-zinc-100">
    {
      project.hasDetails ? (
        <a
          href={translatePath(`/projects/${project.id}`, locale)}
          class="after:absolute after:inset-0 focus:outline-none"
        >
          {project.title}
        </a>
      ) : (
        project.title
      )
    }
  </h3>
  <p class="mt-2 grow text-sm text-zinc-600 dark:text-zinc-400">
    {project.description[locale]}
  </p>
  <ul class="mt-3 flex flex-wrap gap-1.5">
    {
      project.tags.map((tag) => (
        <li class="rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs font-medium text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">
          {tag}
        </li>
      ))
    }
  </ul>
  {
    (project.repoUrl ||
      project.demoUrl ||
      project.npmUrl ||
      project.hasDetails) && (
      <div class="relative z-10 mt-4 flex items-center gap-4 text-sm">
        {project.hasDetails && (
          <a
            href={translatePath(`/projects/${project.id}`, locale)}
            class="font-medium text-indigo-600 hover:underline dark:text-indigo-400"
          >
            {t("projects.details")}
          </a>
        )}
        {project.repoUrl && (
          <a
            href={project.repoUrl}
            target="_blank"
            rel="noopener"
            class="font-medium text-indigo-600 hover:underline dark:text-indigo-400"
          >
            {t("projects.sourceCode")}
          </a>
        )}
        {project.demoUrl && (
          <a
            href={project.demoUrl}
            target="_blank"
            rel="noopener"
            class="font-medium text-indigo-600 hover:underline dark:text-indigo-400"
          >
            {t("projects.liveDemo")}
          </a>
        )}
        {project.npmUrl && (
          <a
            href={project.npmUrl}
            target="_blank"
            rel="noopener"
            class="text-zinc-600 transition-colors hover:text-red-500 dark:text-zinc-400 dark:hover:text-red-500"
            title="npm package"
            aria-label="View on npm"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
            >
              <path d="M1 8h22v7H11v2H7v-2H1z" />
              <path d="M7 8v7" />
              <path d="M14 8v7" />
              <path d="M17 11v4" />
              <path d="M20 11v4" />
              <path d="M23 11v4" />
            </svg>
          </a>
        )}
      </div>
    )
  }
</article>
