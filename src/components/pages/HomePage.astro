---
import Base from "@/layouts/Base.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { siteConfig } from "@/config/site";
import { getArticles } from "@/data/articles";
import { featuredProjects } from "@/data/projects";
import { translatePath, useTranslations, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const recentArticles = (await getArticles(locale)).slice(0, 3);
---

<Base
  title={siteConfig.author}
  description={siteConfig.description[locale]}
  locale={locale}
>
  <section>
    <p class="text-zinc-500 dark:text-zinc-400">{t("home.greeting")}</p>
    <h1
      class="mt-1 text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100"
    >
      {siteConfig.author}
    </h1>
    <p class="mt-3 max-w-prose text-lg text-zinc-600 dark:text-zinc-400">
      {siteConfig.tagline[locale]}
    </p>
    <p class="mt-6 flex gap-3">
      <a
        href={translatePath("/projects/", locale)}
        class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-indigo-700"
      >
        {t("home.viewProjects")}
      </a>
      <a
        href={translatePath("/articles/", locale)}
        class="rounded-md border border-zinc-300 px-4 py-2 text-sm font-medium transition-colors hover:border-zinc-500 dark:border-zinc-700 dark:hover:border-zinc-500"
      >
        {t("home.readArticles")}
      </a>
    </p>
  </section>
  {
    recentArticles.length > 0 && (
      <section class="mt-14">
        <div class="flex items-baseline justify-between">
          <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">
            {t("home.recentArticles")}
          </h2>
          <a
            href={translatePath("/articles/", locale)}
            class="text-sm font-medium text-indigo-600 hover:underline dark:text-indigo-400"
          >
            {t("home.allArticles")} →
          </a>
        </div>
        <div class="mt-4 space-y-6">
          {recentArticles.map((article) => (
            <ArticleCard article={article} locale={locale} />
          ))}
        </div>
      </section>
    )
  }
  <section class="mt-14">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">
        {t("home.featuredProjects")}
      </h2>
      <a
        href={translatePath("/projects/", locale)}
        class="text-sm font-medium text-indigo-600 hover:underline dark:text-indigo-400"
      >
        {t("home.allProjects")} →
      </a>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      {
        featuredProjects.map((project) => (
          <ProjectCard project={project} locale={locale} />
        ))
      }
    </div>
  </section>

  {
    locale === "it" && (
      <section class="mt-14 rounded-lg border border-indigo-200 bg-indigo-50 p-5 dark:border-indigo-900 dark:bg-indigo-950/40">
        <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">
          Ripetizioni di matematica, fisica e informatica
        </h2>
        <p class="mt-2 max-w-prose text-sm text-zinc-600 dark:text-zinc-400">
          Offro anche ripetizioni private per superiori e università — online
          oppure in presenza nella zona di Gravellona Toce e Verbania (VCO).
        </p>
        <p class="mt-3">
          <a
            href="/it/ripetizioni/"
            class="text-sm font-medium text-indigo-600 hover:underline dark:text-indigo-400"
          >
            Scopri di più →
          </a>
        </p>
      </section>
    )
  }
</Base>
