---
import Base from "@/layouts/Base.astro";
import { projects } from "@/data/projects";
import { useTranslations, translatePath, type Locale } from "@/i18n";

interface Props {
  projectId: string;
  locale: Locale;
}

const { projectId, locale } = Astro.props;
const t = useTranslations(locale);
const project = projects.find((p) => p.id === projectId);

if (!project) {
  return Astro.redirect(translatePath("/404", locale));
}
---

<Base
  title={project.title}
  description={project.description[locale]}
  locale={locale}
>
  <div class="mb-6">
    <a
      href={translatePath("/projects", locale)}
      class="text-sm font-medium text-indigo-600 hover:underline dark:text-indigo-400"
    >
      &larr; {t("projects.title")}
    </a>
  </div>

  <h1
    class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100"
  >
    {project.title}
  </h1>

  <p class="mt-4 max-w-prose text-lg text-zinc-600 dark:text-zinc-400">
    {project.description[locale]}
  </p>

  <ul class="mt-4 flex flex-wrap gap-1.5">
    {
      project.tags.map((tag) => (
        <li class="rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs font-medium text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">
          {tag}
        </li>
      ))
    }
  </ul>

  <div class="prose prose-zinc dark:prose-invert mt-10 max-w-none">
    <slot />
  </div>
</Base>
