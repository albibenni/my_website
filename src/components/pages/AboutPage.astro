---
import Base from "@/layouts/Base.astro";
import { siteConfig } from "@/config/site";
import { cv } from "@/data/cv";
import { useTranslations, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<Base title={t("about.title")} description={cv.summary[locale]} locale={locale}>
  <h1
    class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100"
  >
    {t("about.title")}
  </h1>
  <p class="mt-3 max-w-prose text-zinc-600 dark:text-zinc-400">
    {cv.summary[locale]}
  </p>

  {
    siteConfig.cvPdfPath && (
      <p class="mt-5">
        <a
          href={siteConfig.cvPdfPath[locale]}
          download
          class="inline-block rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-indigo-700"
        >
          {t("about.downloadCv")}
        </a>
      </p>
    )
  }

  <section class="mt-12">
    <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">
      {t("about.experience")}
    </h2>
    <div class="mt-4 space-y-8">
      {
        cv.experience.map((job) => (
          <article>
            <h3 class="font-semibold text-zinc-900 dark:text-zinc-100">
              {job.role[locale]} · {job.company}
            </h3>
            <p class="text-sm text-zinc-400 dark:text-zinc-500">
              {job.period[locale]}
              {job.location && <> · {job.location[locale]}</>}
            </p>
            <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-zinc-600 dark:text-zinc-400">
              {job.highlights[locale].map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">
      {t("about.education")}
    </h2>
    <div class="mt-4 space-y-4">
      {
        cv.education.map((entry) => (
          <article>
            <h3 class="font-semibold text-zinc-900 dark:text-zinc-100">
              {entry.degree[locale]} · {entry.institution}
            </h3>
            <p class="text-sm text-zinc-400 dark:text-zinc-500">
              {entry.period[locale]}
            </p>
            {entry.notes && (
              <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
                {entry.notes[locale]}
              </p>
            )}
          </article>
        ))
      }
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">
      {t("about.skills")}
    </h2>
    <div class="mt-4 space-y-4">
      {
        cv.skills.map((group) => (
          <div>
            <h3 class="text-sm font-medium text-zinc-500 dark:text-zinc-400">
              {group.label[locale]}
            </h3>
            <ul class="mt-1.5 flex flex-wrap gap-1.5">
              {group.items.map((item) => (
                <li class="rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs font-medium text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</Base>
